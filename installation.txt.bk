struct.error: unpack requires a buffer of 4 bytes

    num_cameras = struct.unpack('Q', f.read(8))[0]
    camera_id, camera_type, w, h = struct.unpack('IiQQ', f.read(24))
    num_images = struct.unpack('Q', f.read(8))[0]
    # One more
##########

pip install pip_system_certs

# Run the custom trainer.
python examples/custom_trainer.py custom --data-dir examples/data/360_v2/counter/ --data-factor 4 --result-dir ./examples/results/counter/ --init-type random --scale_reg 0.01 --scale-reg-type mean --noise-distribution levy --relocation-type opacity --noise-location 0.0 --noise-scale 0.8 --ppf-min-range 0.2 --ppf-max-range 1.0 --test-every 4 --test-every-offset 0
