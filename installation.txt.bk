# Install Visual Studio. Manual installs of python packages from source seem to use the cl compiler bundled with Visual Studio.
# Install CUDA 12.9

# MSVC version 19.44.35226
# C:\Program Files\Microsoft Visual Studio\2022\Community\VC\Tools\MSVC\14.44.35207\bin\Hostx64\x64

cd C:\Program Files\Microsoft Visual Studio\2022\Community\VC\Auxiliary\Build
vcvars64.bat
set DISTUTILS_USE_SDK=1

# Create conda environment and add PyTorch to it.
conda env create -f environment.yml
conda activate gsplat-custom-mcmc
pip install torch==2.8.0 torchvision==0.23.0 torchaudio==2.8.0 --index-url https://download.pytorch.org/whl/cu129

# Install fused-ssim manually.
cd ..
git clone https://github.com/rahul-goel/fused-ssim.git
cd fused-ssim
git checkout 328dc9836f513d00c4b5bc38fe30478b4435cbb5
python setup.py install

# Install fused-bilagrid manually.
cd ..
git clone https://github.com/harry7557558/fused-bilagrid
cd fused-bilagrid
git checkout 90f9788e57d3545e3a033c1038bb9986549632fe
python setup.py install

# Install the reset of requirements.txt
cd ..
cd gsplat-custom-mcmc
pip install -r examples/requirements.txt

# Install GSplat, with our modifications. (This takes a long while, since it has to compile multiple CUDA files.)
python setup.py install

pip install jaxtyping
pip install git+https://github.com/rmbrualla/pycolmap@cc7ea4b7301720ac29287dbe450952511b32125e

##########
